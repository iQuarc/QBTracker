<UserControl x:Class="QBTracker.Views.ClearTasksDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             MinWidth="340">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                   Text="Clear Tasks" Margin="0,0,0,16" />
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock>
                <Run Text="Keep top" />
                <Run Text="{Binding KeepTopCount, Mode=OneWay}" FontWeight="Bold" />
                <Run Text="tasks" />
            </TextBlock>
            <Slider Minimum="0" Maximum="100"
                    Value="{Binding KeepTopCount}"
                    TickPlacement="BottomRight"
                    TickFrequency="10"
                    IsSnapToTickEnabled="False"
                    Margin="0,8,0,0" />
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock>
                <Run Text="Keep tasks used in the last" />
                <Run Text="{Binding KeepDays, Mode=OneWay}" FontWeight="Bold" />
                <Run Text="days" />
            </TextBlock>
            <Slider Minimum="0" Maximum="100"
                    Value="{Binding KeepDays}"
                    TickPlacement="BottomRight"
                    TickFrequency="10"
                    IsSnapToTickEnabled="False"
                    Margin="0,8,0,0" />
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
            <Button IsDefault="True"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">
                <Button.CommandParameter>
                    <system:Boolean>True</system:Boolean>
                </Button.CommandParameter>
                CLEAR
            </Button>
            <Button IsCancel="True" Margin="8,0,0,0"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">
                <Button.CommandParameter>
                    <system:Boolean>False</system:Boolean>
                </Button.CommandParameter>
                CANCEL
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
